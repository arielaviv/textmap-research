# Anthropic API key — used by the repr-eval chat agent and the eval runner.
ANTHROPIC_API_KEY=

# Vercel AI Gateway key — used for multi-provider model routing in the eval engine.
AI_GATEWAY_API_KEY=

# Mapbox token — used to build static map image URLs for the image representation.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Real-OSM scenes — Cloudflare R2 (S3-compatible) access to the pre-indexed
# OSM city extracts (osm/buildings/{city}.json, osm/streets/{city}.json) in
# Nexma's bucket. Use the SAME values Nexma uses. When unset, real-OSM scenes
# fall back to synthetic.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=
AWS_REGION=auto
LAKEHOUSE_BUCKET=nexma-lakehouse

# Optional alternative to R2 creds: a base URL serving the same
# osm/buildings/{city}.json + osm/streets/{city}.json files over HTTP.
OSM_DATA_BASE_URL=
