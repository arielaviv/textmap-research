# Anthropic API key — used by the repr-eval chat agent and the eval runner.
ANTHROPIC_API_KEY=

# Vercel AI Gateway key — used for multi-provider model routing in the eval engine.
AI_GATEWAY_API_KEY=

# Mapbox token — used to build static map image URLs for the image representation.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: base URL serving pre-indexed OSM city extracts
# (osm/buildings/{city}.json, osm/streets/{city}.json). When unset, the
# real-OSM routes degrade gracefully and only synthetic scenes are available.
OSM_DATA_BASE_URL=
